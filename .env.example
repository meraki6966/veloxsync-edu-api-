# VeloxSync for Education — Backend Environment Variables
# Copy to .env for local development.

# ── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────
# Postgres connection string (Railway, Neon, Supabase, etc.)
DATABASE_URL=postgres://user:password@localhost:5432/veloxsync_edu

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret

# ── Stripe (Education plans) ────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
EDU_STRIPE_WEBHOOK_SECRET=whsec_edu_xxx
EDU_STRIPE_PRICE_TEACHER_PRO=price_xxx
EDU_STRIPE_PRICE_HOMESCHOOL=price_xxx
EDU_STRIPE_PRICE_SCHOOL=price_xxx
# Family Plan — pass priceType: 'monthly' | 'annual' to POST /api/edu/billing/checkout
EDU_STRIPE_PRICE_MONTHLY=price_xxx
EDU_STRIPE_PRICE_ANNUAL=price_xxx

# ── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY=re_xxx
FROM_EMAIL=onboarding@resend.dev

# ── AI / Ei-Core ────────────────────────────────────────
TOGETHER_API_KEY=
MERAKI_MODEL_ID=
MOCK_AI=true

# ── Google Classroom OAuth ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
